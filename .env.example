# Local folders (make sure these exist!)
SCAN_FOLDER=./scans
OUTPUT_FOLDER=./output

# MySQL for Docker Compose
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=merbanhub_db
MYSQL_USER=merbanhub_user
MYSQL_PASSWORD=yourpassword
DATABASE_URL=mysql://merbanhub_user:yourpassword@db:3306/merbanhub_db

# OCR Database Configuration (for direct connection)
DB_HOST=localhost
DB_PORT=3306
DB_USER=merbanhub_user
DB_PASSWORD=yourpassword
DB_NAME=merbanhub_db

# OCR Directory Configuration (optional - uses defaults if not set)
SCAN_DIR=incoming-scan
FULLY_INDEXED_DIR=fully_indexed
PARTIAL_INDEXED_DIR=partially_indexed
FAILED_DIR=failed
PENDING_DIR=pending
DB_FAILED_DIR=db_failed

# OCR Tool Paths (update these to match your system)
POPPLER_PATH=C:\poppler-24.08.0\Library\bin
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# OCR Settings
CONFIDENCE_THRESHOLD=50
